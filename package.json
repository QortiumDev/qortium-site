{
  "name": "qortium-site",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Qortium promotional website — a cleaner chain baseline with a focused QDN home.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "qdn:publish": "node scripts/publish-qdn.mjs",
    "qdn:publish:build": "astro build && node scripts/publish-qdn.mjs",
    "site:deploy": "bash scripts/deploy-site.sh --no-build",
    "site:deploy:build": "bash scripts/deploy-site.sh",
    "release:preview": "bash scripts/release-site.sh --previewnet",
    "release:vps": "bash scripts/release-site.sh --vps",
    "release:all": "bash scripts/release-site.sh --all"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.1.0",
    "@astrojs/sitemap": "^3.3.0",
    "astro": "^5.6.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^5.9.3"
  }
}
