---
// Qortium Core mark — official hexagon emblem, vectorized from
// qortium-protoicon-black-transparent.png. currentColor; tints with the accent.
// Path data lives in src/data/marks.ts (shared with Logo + HeroMark).
import { CORE_EMBLEM } from '../data/marks';
interface Props { size?: number; title?: string; class?: string; }
const { size = 26, title = "Qortium", class: cls = "" } = Astro.props;
const w = Math.round((size * 553) / 638);
---
<svg class={cls} width={w} height={size} viewBox="0 0 553 638" role="img" aria-label={title}>
  <path d={CORE_EMBLEM} fill="currentColor" fill-rule="evenodd" />
</svg>
