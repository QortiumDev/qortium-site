---
import Logo from './Logo.astro';
import { withBase, LINKS } from '../data/site';
---
<footer class="site-footer">
  <div class="container">
    <div class="site-footer__brand">
      <a href={withBase('/')} class="brand">
        <Logo size={22} />
        <span>Qortium</span>
      </a>
      <span class="muted">A complete internet platform, built by the community and run by no company.</span>
    </div>
    <div class="site-footer__bottom">
      <span>Preview software — reviewed and tested, not yet formally audited. Qortium ≠ Qortal.</span>
      <span> · <a href={LINKS.siteRepo}>Source for this site</a></span>
    </div>
  </div>
</footer>
