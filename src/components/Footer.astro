---
import Logo from './Logo.astro';
import { withBase } from '../data/site';
---
<footer class="site-footer">
  <div class="container">
    <div class="site-footer__brand">
      <a href={withBase('/')} class="brand">
        <Logo size={22} />
        <span>Qortium</span>
      </a>
      <span class="muted">A cleaner chain baseline with a focused QDN home.</span>
    </div>
    <div class="site-footer__bottom">
      <span>Preview software — reviewed and tested, not yet formally audited. Qortium ≠ Qortal.</span>
    </div>
  </div>
</footer>
