---
import Logo from './Logo.astro';
import { NAV, ACCENTS, withBase } from '../data/site';
// Highlight the active nav item. Compare against the base-stripped pathname.
const here = Astro.url.pathname.replace(/\/$/, '');
function isCurrent(href: string) {
  const target = withBase(href).replace(/\/$/, '');
  return here === target;
}
---
<header class="site-header">
  <div class="container site-header__inner">
    <a href={withBase('/')} class="brand">
      <Logo size={26} />
      <span>Qortium</span>
    </a>
    <nav class="nav" aria-label="Primary">
      {NAV.map((item) => (
        <a
          href={withBase(item.href)}
          aria-current={isCurrent(item.href) ? 'page' : undefined}
        >{item.label}</a>
      ))}
      <button type="button" class="theme-toggle" aria-label="Toggle light or dark theme" title="Toggle light or dark theme">
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
        </svg>
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
        </svg>
      </button>
      <div class="color-picker">
        <button type="button" class="color-picker__toggle" aria-label="Choose accent color" aria-haspopup="true" aria-expanded="false" title="Accent color">
          <span class="color-picker__dot" aria-hidden="true"></span>
        </button>
        <div class="color-picker__menu" role="menu" hidden>
          <button type="button" class="color-picker__swatch color-picker__swatch--default" data-accent="" role="menuitemradio" aria-checked="false" aria-label="Default accent" title="Default"></button>
          {ACCENTS.map((a) => (
            <button
              type="button"
              class="color-picker__swatch"
              data-accent={a.id}
              role="menuitemradio"
              aria-checked="false"
              aria-label={`${a.label} accent`}
              title={a.label}
              style={`background:${a.hex}`}
            ></button>
          ))}
        </div>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var root = document.documentElement;
    function norm(v) {
      v = typeof v === 'string' ? v.trim().toLowerCase() : '';
      return v === 'dark' || v === 'light' ? v : null;
    }

    // Toggle: the user's choice persists (used standalone and as an override
    // between host changes). A later host update can still re-theme the page.
    var btn = document.querySelector('.theme-toggle');
    if (btn) {
      btn.addEventListener('click', function () {
        var current = root.getAttribute('data-theme');
        var effective =
          current ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        var next = effective === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        try { localStorage.setItem('theme', next); } catch (e) {}
      });
    }

    // Live host display-settings sync (Home/Hub post these to the embedded view).
    // Host updates ALWAYS apply — including theme, even after a manual toggle.
    var ACCENTS = ['green','blue','orange','purple','red','teal','cyan','pink','yellow'];
    var SIZES = ['extra-small','small','medium','large','extra-large','huge'];
    function inList(v, list) {
      v = typeof v === 'string' ? v.trim().toLowerCase() : '';
      return list.indexOf(v) >= 0 ? v : null;
    }
    // Persist host changes too, so they survive this multi-page site's full-page
    // navigations (the pre-paint script in BaseLayout re-applies them on load).
    function lsSet(k, v) { try { localStorage.setItem(k, v); } catch (e) {} }
    function applyTheme(v) { var t = norm(v); if (t) { root.setAttribute('data-theme', t); lsSet('qdnTheme', t); } }
    function applyAccent(v) { var a = inList(v, ACCENTS); if (a) { root.setAttribute('data-accent', a); lsSet('qdnAccent', a); } }
    function applyTextSize(v) { var s = inList(v, SIZES); if (s) { root.setAttribute('data-text-size', s); lsSet('qdnTextSize', s); } }

    window.addEventListener('message', function (event) {
      var d = event.data;
      if (!d || typeof d !== 'object' || typeof d.action !== 'string') return;
      switch (d.action) {
        case 'THEME_CHANGED':
          applyTheme(d.theme != null ? d.theme : d.qdnTheme);
          break;
        case 'ACCENT_CHANGED':
          applyAccent(d.accent != null ? d.accent : d.qdnAccent);
          break;
        case 'TEXT_SIZE_CHANGED':
          applyTextSize(d.textSize != null ? d.textSize : d.qdnTextSize);
          break;
        case 'DISPLAY_SETTINGS_CHANGED':
          applyTheme(d.theme != null ? d.theme : d.qdnTheme);
          applyAccent(d.accent != null ? d.accent : d.qdnAccent);
          applyTextSize(d.textSize != null ? d.textSize : d.qdnTextSize);
          break;
      }
    });
  })();
</script>

<!-- Accent color picker. Standalone/gateway only (hidden via [data-embedded] when
     the host owns the accent). Writes the manual choice to localStorage 'accent',
     which the BaseLayout pre-paint re-applies on each page load. -->
<script is:inline>
  (function () {
    var root = document.documentElement;
    var ACCENTS = ['green','blue','orange','purple','red','teal','cyan','pink','yellow'];
    function inList(v) { v = typeof v === 'string' ? v.trim().toLowerCase() : ''; return ACCENTS.indexOf(v) >= 0 ? v : null; }
    function lsSet(k, v) { try { localStorage.setItem(k, v); } catch (e) {} }
    function lsDel(k) { try { localStorage.removeItem(k); } catch (e) {} }

    var picker = document.querySelector('.color-picker');
    if (!picker) return;
    var toggle = picker.querySelector('.color-picker__toggle');
    var menu = picker.querySelector('.color-picker__menu');
    var swatches = Array.prototype.slice.call(picker.querySelectorAll('.color-picker__swatch'));

    function syncPressed() {
      var cur = inList(root.getAttribute('data-accent'));
      swatches.forEach(function (s) {
        var a = s.getAttribute('data-accent') || '';
        var on = a ? a === cur : !cur;
        s.setAttribute('aria-checked', on ? 'true' : 'false');
      });
    }
    function openMenu() { menu.hidden = false; toggle.setAttribute('aria-expanded', 'true'); syncPressed(); }
    function closeMenu() { menu.hidden = true; toggle.setAttribute('aria-expanded', 'false'); }

    toggle.addEventListener('click', function (e) {
      e.stopPropagation();
      if (menu.hidden) openMenu(); else closeMenu();
    });
    swatches.forEach(function (s) {
      s.addEventListener('click', function () {
        var a = inList(s.getAttribute('data-accent'));
        if (a) { root.setAttribute('data-accent', a); lsSet('accent', a); }
        else { root.removeAttribute('data-accent'); lsDel('accent'); }
        syncPressed();
        closeMenu();
      });
    });
    document.addEventListener('click', function (e) { if (!picker.contains(e.target)) closeMenu(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' || e.key === 'Esc') closeMenu(); });
    syncPressed();
  })();
</script>
