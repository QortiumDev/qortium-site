---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, withBase, absUrl } from '../data/site';

interface Props {
  title: string;
  description: string;
  /** Path of this page, e.g. "/why" — used for canonical + OG url. */
  path?: string;
  /** Optional JSON-LD object(s) to embed. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  ogImage?: string;
}
const { title, description, path = '/', jsonLd, ogImage } = Astro.props;

// Canonical / OG absolute URLs use the public gateway path (not the relative
// in-page links). In-page assets/links use withBase() (relative).
const canonical = absUrl(path);
const ogImg = absUrl(ogImage ?? SITE.ogImage);
const fullTitle = title.includes('Qortium') ? title : `${title} · Qortium`;
const jsonLdList = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Resolve display settings before first paint (avoids a flash).
         Embedded in Home/Hub (Core injects _qdnContext === "render" plus
         _qdnTheme/_qdnAccent/_qdnTextSize and ?theme/?accent/?textSize): mirror
         the host's theme, accent, and text size. Standalone: theme follows the
         saved manual toggle, else the system (prefers-color-scheme); accent and
         text size stay at our defaults. Live host changes are handled by the
         Header script and always apply (they are never blocked by a manual toggle). -->
    <script is:inline>
      (function () {
        var root = document.documentElement;
        var ACCENTS = ['green','blue','orange','purple','red','teal','cyan','pink','yellow'];
        var SIZES = ['extra-small','small','medium','large','extra-large','huge'];
        function normTheme(v) {
          v = typeof v === 'string' ? v.trim().toLowerCase() : '';
          return v === 'dark' || v === 'light' ? v : null;
        }
        function inList(v, list) {
          v = typeof v === 'string' ? v.trim().toLowerCase() : '';
          return list.indexOf(v) >= 0 ? v : null;
        }
        function lsGet(k) { try { return localStorage.getItem(k); } catch (e) { return null; } }
        function lsSet(k, v) { try { localStorage.setItem(k, v); } catch (e) {} }
        var qp = null;
        try { qp = new URLSearchParams(location.search); } catch (e) {}
        function q() {
          if (!qp) return null;
          for (var i = 0; i < arguments.length; i++) {
            var x = qp.get(arguments[i]);
            if (x != null) return x;
          }
          return null;
        }
        var embedded = window._qdnContext === 'render';

        // Host display settings (theme/accent/text size) reach us as QUERY PARAMS
        // — on the first render from Home, and on the internal links we rewrite
        // (see Header) so they ride along through navigation. We deliberately
        // IGNORE the injected window._qdn* vars: Core fills them with its OWN
        // defaults (light / medium / green) on any param-less request, which would
        // clobber the real settings on every page change. localStorage keeps the
        // last real values as a fallback.
        var qpTheme = normTheme(q('theme', 'qdnTheme'));
        var qpAccent = inList(q('accent', 'qdnAccent'), ACCENTS);
        var qpSize = inList(q('textSize', 'text-size', 'qdnTextSize'), SIZES);
        if (qpTheme) lsSet('qdnTheme', qpTheme);
        if (qpAccent) lsSet('qdnAccent', qpAccent);
        if (qpSize) lsSet('qdnTextSize', qpSize);

        if (embedded) {
          // Embedded in Home/Hub: the HOST owns theme, accent, and text size and
          // re-applies them on every page load. Follow the host for all three (and
          // hide our standalone theme toggle via [data-embedded]) — a local
          // override would just flip back to the host's value on the next page.
          root.setAttribute('data-embedded', '');
          var theme = qpTheme || normTheme(lsGet('qdnTheme'));
          if (theme) root.setAttribute('data-theme', theme);
          var accent = qpAccent || inList(lsGet('qdnAccent'), ACCENTS);
          if (accent) root.setAttribute('data-accent', accent);
          var size = qpSize || inList(lsGet('qdnTextSize'), SIZES);
          if (size) root.setAttribute('data-text-size', size);
        } else {
          // Standalone browser: the manual toggle is the only authority; otherwise
          // the OS preference applies via CSS.
          var manual = normTheme(lsGet('theme'));
          if (manual) root.setAttribute('data-theme', manual);
        }
      })();
    </script>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <meta name="theme-color" content="#4f5bd5" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Qortium" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImg} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImg} />

    {jsonLdList.map((obj) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(obj)} />
    ))}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <!-- Live release versions: fill any <ReleaseTag> (data-release) elements from
         the GitHub Releases API at page load. Uses /releases?per_page=1 because
         these are prereleases (excluded by /releases/latest). Fails silently —
         tags stay hidden if GitHub is unreachable. Works in a browser, Hub, or Home. -->
    <script is:inline>
      (function () {
        var els = Array.prototype.slice.call(document.querySelectorAll('[data-release]'));
        if (!els.length) return;
        var repos = {};
        els.forEach(function (el) { repos[el.getAttribute('data-release')] = true; });
        Object.keys(repos).forEach(function (repo) {
          fetch('https://api.github.com/repos/' + repo + '/releases?per_page=1', {
            headers: { Accept: 'application/vnd.github+json' },
          })
            .then(function (r) { return r.ok ? r.json() : null; })
            .then(function (data) {
              var tag = data && data[0] && data[0].tag_name;
              if (typeof tag !== 'string' || !tag) return;
              els
                .filter(function (el) { return el.getAttribute('data-release') === repo; })
                .forEach(function (el) {
                  var prefix = el.getAttribute('data-release-prefix') || '';
                  var suffix = el.getAttribute('data-release-suffix') || '';
                  el.textContent = '';
                  if (prefix) el.appendChild(document.createTextNode(prefix));
                  if (el.hasAttribute('data-release-code')) {
                    var c = document.createElement('code');
                    c.textContent = tag;
                    el.appendChild(c);
                  } else {
                    el.appendChild(document.createTextNode(tag));
                  }
                  if (suffix) el.appendChild(document.createTextNode(suffix));
                  el.hidden = false;
                });
            })
            .catch(function () {});
        });
      })();
    </script>
  </body>
</html>
