---
import BaseLayout from '../layouts/BaseLayout.astro';
import QdnLink from '../components/QdnLink.astro';
import ChatMark from '../components/ChatMark.astro';
import TrustMark from '../components/TrustMark.astro';
import AppMark from '../components/AppMark.astro';
import { APPS, absUrl, withBase } from '../data/site';

const title = 'Qortium Apps';
const description =
  'QDN Q-Apps published on the network and opened inside Qortium Home, with no separate installs.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Qortium Apps',
  description,
  url: absUrl('/apps'),
};
---
<BaseLayout title={title} description={description} path="/apps" jsonLd={jsonLd}>
  <section class="hero">
    <div class="container">
      <h1>Apps published on QDN</h1>
      <p class="lede measure">
        These are QDN Q-Apps: apps published as QDN resources that open inside
        Qortium Home. There are no separate app installers. Home opens the app,
        keeps account actions behind its bridge, and lets each app update through
        the network.
      </p>
      <p class="muted measure">
        Chat and Trust also have dedicated pages because they are central to how
        Qortium works, but they are still QDN apps like the rest of this catalog.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary" href={withBase('/downloads')}>Get Qortium Home</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--4">
        {APPS.map((app) => (
          <div class="card">
            <div class="tile__head tile__head--top">
              <span class="card__mark">
                {app.mark === 'chat' ? (
                  <ChatMark size={40} title="Qortium Chat" />
                ) : app.mark === 'trust' ? (
                  <TrustMark size={40} title="Qortium Trust" />
                ) : (
                  <AppMark app={app.mark} size={40} />
                )}
              </span>
              <h3>{app.name}</h3>
            </div>
            <p class="muted">{app.description}</p>
            <p class="muted">Open <QdnLink resource={app.qdnResource} /> in Home.</p>
            {app.page && (
              <div class="btn-row">
                <a class="btn btn--ghost" href={withBase(app.page)}>
                  {app.name} page
                </a>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
