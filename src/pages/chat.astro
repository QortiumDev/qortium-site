---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChatMark from '../components/ChatMark.astro';
import { CHAT, LINKS, withBase } from '../data/site';

const title = 'Qortium Chat';
const description = 'Talk privately or in public on a network that has no operator reading over your shoulder.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Qortium Chat',
  applicationCategory: 'CommunicationApplication',
  operatingSystem: 'Runs in Qortium Home (desktop & Android)',
  license: CHAT.license,
  url: CHAT.repo,
  description: 'Talk privately or in public on a network that has no operator reading over your shoulder.',
  sameAs: [CHAT.repo],
};
---
<BaseLayout title={title} description={description} path="/chat" jsonLd={jsonLd}>
  <section class="hero">
    <div class="container">
      <div class="hero-head">
        <ChatMark size={44} title="Qortium Chat" />
        <h1>Talk freely, in private or in public</h1>
      </div>
      <p class="lede measure">
        Qortium Chat lets you message people and join group conversations with
        no operator hosting the rooms or reading along. Private groups are
        encrypted just for the people in them, and you never have to handle any
        keys yourself.
      </p>
      <p class="muted measure">
        There is no moderator who can read all your messages or shut you out. In
        group chats, you decide what to take part in and what to ignore.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary" href={withBase('/downloads')}>Get Qortium Home</a>
        <a class="btn btn--ghost" href={LINKS.chatRepo}>Source repo</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>What it does</h2>
      <div class="grid grid--2">
        <div class="card">
          <h3>Private groups, encrypted for you</h3>
          <p class="muted">
            Closed group chats are encrypted automatically, just for the people
            in them. You never have to set up or remember keys.
          </p>
        </div>
        <div class="card">
          <h3>Nothing slips out in the clear</h3>
          <p class="muted">
            Messages in a private group can't be sent unencrypted, so a private
            conversation stays private.
          </p>
        </div>
        <div class="card">
          <h3>Open public rooms</h3>
          <p class="muted">
            Want to talk out in the open? Qortium brings back the public chat
            room, where anyone can join the conversation.
          </p>
        </div>
        <div class="card">
          <h3>You choose how long to keep it</h3>
          <p class="muted">
            Pick how long your chats are kept. The default is about a day, and
            you can save them for longer if you want.
          </p>
        </div>
        <div class="card">
          <h3>Share images and files in open rooms</h3>
          <p class="muted">
            Public group chats can carry image and file attachments. Private
            and direct messages don't have attachments yet — that needs Home
            to encrypt files before they're published, which isn't built yet.
          </p>
        </div>
        <div class="card">
          <h3>Deleting leaves a marker, not a hole</h3>
          <p class="muted">
            Delete a message and it's replaced with a visible marker right
            away. The message itself isn't erased from the chain early — it
            goes away on its own once your normal retention period ends.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>How it fits together</h2>
      <div class="grid grid--2">
        <div class="card">
          <h3>Its own app, not locked in</h3>
          <p class="muted">
            Chat is a separate app that runs inside Home, not baked into it. So
            anyone can build their own version, while your keys stay safe in
            Home.
          </p>
        </div>
        <div class="card">
          <h3>Start helping run the network</h3>
          <p class="muted">
            Right from inside the chat app you can start minting — helping produce
            blocks with your own node to secure the network, which builds your
            voting weight. Home handles the keys for you.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Get started</h2>
      <div class="card">
        <p class="muted">
          Chat runs inside Qortium Home, so there's nothing extra to download.
          Open Home and you're ready to talk.
        </p>
        <div class="btn-row">
          <a class="btn btn--primary" href={withBase('/downloads')}>Get Qortium Home</a>
          <a class="btn btn--ghost" href={LINKS.chatRepo}>Source repo</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
