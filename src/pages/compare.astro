---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../data/site';

const title = 'Qortium vs Qortal';
const description = 'How Qortium and Qortal compare in plain terms.';

const rows = [
  {
    dim: 'Overall',
    qortium: 'A streamlined protocol that grew out of Qortal — a foundation for chains, still in preview.',
    qortal: 'A full, live platform and coin economy.',
  },
  {
    dim: 'App',
    qortium: 'Home: a simple app for your wallet, the network, and content.',
    qortal: 'Hub: chat, wallet, publishing, hosted access, and voice.',
  },
  {
    dim: 'Coin',
    qortium: "Starts with no coin of its own; you don't need to buy anything to use it, and a coin is added only by community vote.",
    qortal: 'Built around the QORT coin and its economy.',
  },
  {
    dim: 'Names',
    qortium: 'Choose and change your primary name anytime, even if you own several.',
    qortal: 'Your first name is fixed, and owning more names locks it.',
  },
  {
    dim: 'Apps per name',
    qortium: 'Publish many apps or sites under one name, each with its own icon.',
    qortal: "Effectively one or two per name, all using the name's avatar.",
  },
  {
    dim: 'Selling names',
    qortium: 'Sell a name privately to one person, or give one for free that they choose to accept — no sniping.',
    qortal: 'Sales are public, so anyone can buy first.',
  },
  {
    dim: 'Groups',
    qortium: 'Groups can be renamed and sold, including private sales.',
    qortal: "Group names are fixed and groups can't be sold.",
  },
  {
    dim: 'Deleting content',
    qortium: 'You can remove your content from the network.',
    qortal: 'No built-in way to delete published content.',
  },
  {
    dim: 'Content ratings',
    qortium: 'Rate any published content, built into the core, so the best rises to the top.',
    qortal: 'Only limited ratings, built on top of polls.',
  },
  {
    dim: 'Account reputation',
    qortium: "Built-in reputation from on-chain ratings adjusts how much each account's minting and votes count, and resists fake accounts.",
    qortal: 'Uses sponsorship and minting levels.',
  },
  {
    dim: 'Updates',
    qortium: 'Off by default; an update only applies after the community approves it — nothing is pushed to you silently.',
    qortal: 'Updates are approved by its developer group.',
  },
  {
    dim: 'Private group chat',
    qortium: 'Private group chats are encrypted automatically — no keys to manage.',
    qortal: 'Encrypts in the app and shares group keys over its network.',
  },
  {
    dim: 'Chat history',
    qortium: 'Keep your chat history as long as you want; the default is about a day.',
    qortal: 'Messages are dropped after about a day.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Qortium vs Qortal',
  description: 'How Qortium and Qortal compare in plain terms.',
  about: ['Qortium', 'Qortal'],
  url: 'https://qortal.link/Qortium/compare',
};
---
<BaseLayout title={title} description={description} path="/compare" jsonLd={jsonLd}>
  <section class="section">
    <div class="container">
      <h1>Different goals, not a replacement</h1>
      <p class="lede measure">
        Qortium and Qortal share a starting point but aim at different things. Here's how they compare.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Where they differ</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th scope="col">Dimension</th>
              <th scope="col">Qortium</th>
              <th scope="col">Qortal</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((r) => (
              <tr>
                <td><strong>{r.dim}</strong></td>
                <td>{r.qortium}</td>
                <td>{r.qortal}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="muted measure">
        Qortium can adopt Qortal's more advanced features — like voice chat or
        Reticulum — later; the focus now is the foundation and community governance.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary" href={withBase('/downloads')}>Join Previewnet</a>
      </div>
    </div>
  </section>
</BaseLayout>
