---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase, absUrl } from '../data/site';

const title = 'How Qortium compares';
const description =
  'How Qortium lines up against Qortal and the broad kinds of platforms people compare it to — other decentralized networks, a currency chain, and a company-run suite of apps.';

// Columns left-to-right run most-similar to least, and decentralized to
// centralized: Qortium, Qortal, then three general categories (no brand names).
const cols = ['Qortium', 'Qortal', 'Decentralized platform', 'Crypto coin', 'Company platform'];

// The big picture first, then finer Qortium-vs-Qortal detail. Category cells are
// kept honest: "—" where the thing genuinely has no equivalent, hedged where it
// varies. Cells are deliberately terse so the wide table stays readable.
const rows = [
  {
    dim: 'What it is',
    cells: ['A complete internet platform', 'A complete internet platform', 'A decentralized or federated network', 'Mainly a digital currency', 'A whole suite of apps from one company'],
  },
  {
    dim: 'What you do with it',
    cells: ['Post, message, publish sites & apps, store files', 'Much the same', 'Often one area, like social or messaging', 'Send and hold value', "A lot — but all within one company's walls"],
  },
  {
    dim: 'Who runs it',
    cells: ['Anyone running a node — no company', 'Anyone running a node', 'Separate servers run by volunteers', 'Anyone running a node', "The company's servers"],
  },
  {
    dim: 'Can you be banned or censored?',
    cells: ['No — you choose what you see', 'No', "Your server's admin can; you can switch servers", 'Payments are hard to block', 'Yes — one ban can lock you out of all of it'],
  },
  {
    dim: 'Who decides its direction',
    cells: ['The community; open voting is being built', 'Its community and developers', 'The project, or each server on its own', 'Core developers and big holders', 'The company and its investors'],
  },
  {
    dim: 'Do you need to buy a coin?',
    cells: ['No coin by default', 'Uses its QORT coin', 'Usually no; some use a token', 'Yes — the coin is the point', 'You pay with money or your data'],
  },
  {
    dim: 'Your content and name',
    cells: ['Yours — portable, and you can delete it', 'Yours', 'Often tied to the server you joined', '—', 'They hold it and set the rules'],
  },
  {
    dim: 'How far along it is',
    cells: ['Preview (Previewnet), still being shaped', 'Live for years', 'Some are well-established', 'Many are long-established', 'Established'],
  },
  {
    dim: 'Names',
    cells: ['Choose and change your name anytime', 'First name is fixed; more names lock it', 'A handle tied to your server', '—', 'A username they can reclaim'],
  },
  {
    dim: 'Selling names',
    cells: ['Private sale to one person, or gift it — no sniping', 'Public sales — anyone can buy first', '—', '—', '—'],
  },
  {
    dim: 'Apps per name',
    cells: ['Many, each with its own icon', 'About one or two', '—', '—', '—'],
  },
  {
    dim: 'Groups',
    cells: ['Rename and sell, even privately', "Fixed names, can't be sold", '—', '—', '—'],
  },
  {
    dim: 'Content ratings',
    cells: ['Built into the core, so the best rises', 'Limited, built on top of polls', 'Rarely built in', '—', "The company's algorithm decides"],
  },
  {
    dim: 'Account reputation',
    cells: ['On-chain ratings adjust vote and mint weight; resists fakes', 'Sponsorship and minting levels', 'Per server, if any', '—', 'Internal, if any'],
  },
  {
    dim: 'Updates',
    cells: ['Off by default; community-approved', 'Approved by its developer group', 'Each server updates itself', 'Depends on the chain', 'Pushed by the company'],
  },
  {
    dim: 'Private group chat',
    cells: ['Auto-encrypted, no keys to manage', 'Encrypts in-app; shares keys over its network', 'Sometimes end-to-end encrypted', '—', 'The company can often read it'],
  },
  {
    dim: 'Chat history',
    cells: ['Keep it as long as you want (default ~a day)', 'Dropped after about a day', 'Held by your server', '—', 'Stored on their servers'],
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'How Qortium compares',
  description,
  about: ['Qortium', 'Qortal', 'decentralized platforms', 'cryptocurrency'],
  url: absUrl('/compare'),
};
---
<BaseLayout title={title} description={description} path="/compare" jsonLd={jsonLd}>
  <section class="section">
    <div class="container">
      <h1>How Qortium compares</h1>
      <p class="lede measure">
        Qortium is a complete internet platform. Here's how it lines up against
        Qortal — its closest relative — and the broad kinds of platforms people
        compare it to.
      </p>
      <p class="muted measure">
        By <strong>decentralized platform</strong> we mean another decentralized
        or federated network — broader than a coin, but usually narrower than
        Qortium or split across separate servers; <strong>crypto coin</strong>, a
        chain built mainly around a currency (private or not);
        <strong>company platform</strong>, a whole suite of apps run by a single
        company.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th scope="col">&nbsp;</th>
              {cols.map((c) => <th scope="col">{c}</th>)}
            </tr>
          </thead>
          <tbody>
            {rows.map((r) => (
              <tr>
                <td><strong>{r.dim}</strong></td>
                {r.cells.map((cell) => <td>{cell}</td>)}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="muted measure">
        Each of these has its strengths — a currency chain at moving value, other
        decentralized networks within their own corner. Qortium's aim is to bring
        the everyday things you go online for into one community-run platform:
        broad like a company's suite, but with no company in charge and no
        patchwork of separate servers. It can take on more advanced features over
        time; the focus now is the foundation and the community that steers it.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary" href={withBase('/downloads')}>Join Previewnet</a>
      </div>
    </div>
  </section>
</BaseLayout>
