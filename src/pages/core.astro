---
import BaseLayout from '../layouts/BaseLayout.astro';
import CoreMark from '../components/CoreMark.astro';
import { withBase, LINKS } from '../data/site';

const title = 'Qortium Core';
const description = 'The network software — the chain itself, built to be understood and easy to launch your own from.';

const cleanup = [
  {
    h: 'No coin to start',
    p: 'A new Qortium chain begins with no coin of its own — none made or handed out in advance.',
  },
  {
    h: 'Use it without owning a coin',
    p: 'With no coin, transactions are secured by a small bit of work from your own device, so anyone can transact.',
  },
  {
    h: 'A coin only by community vote',
    p: 'Anyone can create their own assets freely, but the chain has no coin for fees unless the development group votes to add one.',
  },
  {
    h: 'A cleaner, documented base',
    p: 'Qortium clears out Qortal-specific assumptions and explains the rest in plain language.',
  },
];

const directions = [
  {
    h: 'Community-approved updates',
    p: 'Updates are off by default and only apply after the community approves them, so no one can push software to you silently.',
  },
  {
    h: 'Open, community-driven governance',
    p: 'The development group is open to anyone. The direction: admins approve updates and the fee coin, while members vote admins in or out — kept fair by trust scores.',
  },
  {
    h: 'Changes by vote, not by force',
    p: 'Important network settings can change through on-chain votes instead of forced restarts.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Qortium Core',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Linux, macOS, Windows',
  license: 'https://www.gnu.org/licenses/gpl-3.0.html',
  url: LINKS.coreRepo,
  sameAs: [LINKS.coreRepo, LINKS.coreReleases],
};
---
<BaseLayout title={title} description={description} path="/core" jsonLd={jsonLd}>
  <section class="hero">
    <div class="container">
      <div class="hero-head">
        <CoreMark size={44} title="Qortium Core" />
        <h1>The network software — the chain itself</h1>
      </div>
      <p class="lede measure">
        Qortium Core is a cleaned-up evolution of Qortal, made to be easy to
        understand and to launch your own chain from.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary" href={LINKS.coreRepo}>Open qortium-core</a>
        <a class="btn btn--ghost" href={LINKS.coreDocs}>Docs</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>A clean starting point</h2>
      <div class="grid grid--2">
        {cleanup.map((c) => (
          <div class="card">
            <h3>{c.h}</h3>
            <p class="muted">{c.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Where the chain is heading</h2>
      <div class="grid grid--2">
        <a class="card card--link" href={withBase('/trust')}>
          <h3>Built-in account reputation</h3>
          <p class="muted">
            Accounts earn reputation that shapes their minting and voting — see Trust.
          </p>
        </a>
        {directions.map((d) => (
          <div class="card">
            <h3>{d.h}</h3>
            <p class="muted">{d.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
