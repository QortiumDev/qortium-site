---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase, LINKS, PREVIEWNET } from '../data/site';

const title = 'Qortium docs & sources | Repos, changelogs, release notes';
const description =
  'Curated Qortium source list: repositories, changelogs, release notes, and the core documentation index.';

const repos = [
  {
    name: 'qortium-core',
    href: LINKS.coreRepo,
    tag: 'Chain layer · GPL-3.0',
    p: 'The Java node: chain processing, local APIs, networking, build tooling, and the design docs. A stripped-down, cleaned-up fork of Qortal Core.',
  },
  {
    name: 'qortium-home',
    href: LINKS.homeRepo,
    tag: 'App · 0BSD',
    p: 'The desktop and Android companion app: wallets, node status, QDN browsing, and session tabs with approval-gated account actions.',
  },
];

const documents = [
  {
    h: 'Core changelog',
    href: LINKS.coreChangelog,
    p: 'Plain-language, non-developer-first record of what changed and why, release by release.',
  },
  {
    h: 'Core docs index',
    href: LINKS.coreDocs,
    p: 'The full design documentation set inside the core repository, grouped by topic.',
  },
  {
    h: 'Core preview releases',
    href: LINKS.coreReleases,
    p: 'Tagged preview builds and release notes on GitHub Releases. Binaries live here, never on this site.',
  },
  {
    h: 'Home releases',
    href: LINKS.homeReleases,
    p: 'Preview builds and notes for the Qortium Home app across desktop and Android.',
  },
];

const topics = [
  'chain-design',
  'trust · account-trust-network',
  'trust · aura-trust-tier-minting',
  'lite-node · plan',
  'qdn',
  'cross-chain',
  'upstream comparison',
  'development',
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Qortium docs & sources',
  description,
  url: 'https://qortal.link/Qortium/docs',
  hasPart: [LINKS.coreRepo, LINKS.homeRepo, LINKS.coreChangelog, LINKS.coreDocs],
};
---
<BaseLayout title={title} description={description} path="/docs" jsonLd={jsonLd}>
  <!-- 1. INTRO -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Docs &amp; sources</p>
      <h1>Read the source, not the spin</h1>
      <p class="lede measure">
        Both major repositories keep human-readable changelogs aimed at
        non-developers first. This page is the curated map — repositories,
        changelogs, release notes, and the documentation index, so any claim on
        this site can be checked against its source.
      </p>
    </div>
  </section>

  <!-- 2. REPOSITORIES -->
  <section class="section--tight section--soft">
    <div class="container">
      <p class="eyebrow">Repositories</p>
      <h2>The two source repositories</h2>
      <div class="grid grid--2" style="margin-top:1.5rem;">
        {repos.map((r) => (
          <a class="card card--link" href={r.href}>
            <span class="card__tag">{r.tag}</span>
            <h3>{r.name}</h3>
            <p class="muted">{r.p}</p>
            <span aria-hidden="true">Open on GitHub →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. KEY DOCUMENTS -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Key documents</p>
      <h2>Changelogs, docs, and release notes</h2>
      <div class="grid grid--2" style="margin-top:1.5rem;">
        {documents.map((d) => (
          <a class="card card--link" href={d.href}>
            <h3>{d.h}</h3>
            <p class="muted">{d.p}</p>
            <span aria-hidden="true">Read →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. CORE DOCUMENTATION TOPICS -->
  <section class="section--tight section--soft">
    <div class="container">
      <p class="eyebrow">Core documentation topics</p>
      <h2>What the design docs cover</h2>
      <p class="muted measure">
        The core docs index is organized into focused areas. Several of these
        describe directions still being specified — read them as design intent,
        not finished guarantees.
      </p>
      <ul class="pills" style="margin-top:1.25rem;" aria-label="Core documentation topics">
        {topics.map((t) => <li>{t}</li>)}
      </ul>
    </div>
  </section>

  <!-- 5. HOW TO VERIFY CLAIMS -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Verification</p>
      <h2>How to verify claims</h2>
      <div class="notice notice--accent">
        <h3>Check governance details live, against the right chain</h3>
        <p class="muted">
          Governance details — such as which dev group controls updates — can be
          checked live against dev group id <code>1</code> via the node API on
          both chains. The formal public governance roster and threshold are
          <strong> not yet fully specified</strong> for Qortium; treat that as open.
        </p>
        <p class="muted" style="margin:0;">
          Qortium is <strong>not</strong> Qortal. Query Qortium Previewnet APIs
          directly — the local Core API runs on port <code>{PREVIEWNET.localApiPort}</code>
          {' '}(<code>http://localhost:{PREVIEWNET.localApiPort}</code>). Do not use
          public Qortal gateways as evidence for Qortium resources.
        </p>
      </div>
    </div>
  </section>

  <!-- 6. CTA -->
  <section class="section--tight section--soft">
    <div class="container cta-band">
      <h2>Start at the source</h2>
      <p class="muted measure" style="margin-inline:auto;">
        The repositories are the ground truth. The comparison page shows where the
        two projects diverge, with caveats where public sources are incomplete.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary" href={LINKS.coreRepo}>qortium-core</a>
        <a class="btn btn--ghost" href={LINKS.homeRepo}>qortium-home</a>
        <a class="btn btn--ghost" href={withBase('/compare')}>Qortium vs Qortal</a>
      </div>
    </div>
  </section>
</BaseLayout>
