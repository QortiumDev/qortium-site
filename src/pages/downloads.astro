---
import BaseLayout from '../layouts/BaseLayout.astro';
import CoreMark from '../components/CoreMark.astro';
import HomeMark from '../components/HomeMark.astro';
import ChatMark from '../components/ChatMark.astro';
import TrustMark from '../components/TrustMark.astro';
import ReleaseTag from '../components/ReleaseTag.astro';
import QdnLink from '../components/QdnLink.astro';
import { RELEASES, CHAT, TRUST, absUrl, withBase } from '../data/site';

const title = 'Get Qortium';
const description =
  'Install Qortium Home to step into the platform, then run your own node — let Home set it up for you, or run the node software by hand — to help secure the network and earn a say in it.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Get Qortium',
  description,
  url: absUrl('/downloads'),
};
---
<BaseLayout title={title} description={description} path="/downloads" jsonLd={jsonLd}>
  <section class="hero">
    <div class="container">
      <div class="hero-head">
        <HomeMark size={44} title="Qortium Home" />
        <h1>Your front door to Qortium</h1>
      </div>
      <p class="lede measure">
        Qortium Home is the doorway to the whole platform — one app for your
        account, the network, and everything published on it, for desktop and
        Android. Install it and you're connected to the network straight away.
      </p>
      <p class="muted">
        <ReleaseTag class="badge badge--preview" repo={RELEASES.home.repoSlug} />
        {RELEASES.home.platforms.join(', ')}. License <code>{RELEASES.home.license}</code>.
      </p>
      <p class="muted">
        macOS builds include a universal DMG plus legacy DMGs for macOS 11 and
        macOS 10.15, so older Macs are covered too. No iOS build yet.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary" href={RELEASES.home.releases}>Get Qortium Home</a>
      </div>
      <p class="muted">These are early builds for testing while the network takes shape.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Comes with Home</h2>
      <p class="muted measure">No separate downloads — these open right inside Home.</p>
      <div class="grid grid--2">
        <div class="card">
          <div class="tile__head tile__head--top">
            <span class="card__mark"><ChatMark size={30} title={CHAT.name} /></span>
            <h3>{CHAT.name}</h3>
          </div>
          <p class="muted">
            Private and public group chat. Open <QdnLink resource={CHAT.qdnResource} /> in Home.
          </p>
        </div>
        <div class="card">
          <div class="tile__head tile__head--top">
            <span class="card__mark"><TrustMark size={30} title={TRUST.name} /></span>
            <h3>{TRUST.name}</h3>
          </div>
          <p class="muted">
            See and build account reputation. Open <QdnLink resource={TRUST.qdnResource} /> in Home.
          </p>
        </div>
      </div>
      <p class="muted measure">
        Help, Wallet, Names, Groups, Profiles, Chain Explorer, Minting, Network,
        Node, and more also open inside Home as QDN apps — no separate downloads
        for any of them. <a href={withBase('/apps')}>See all apps</a>.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Run your own node</h2>
      <p class="lede measure">
        Home can connect you through a public network of nodes, so you're online
        right away. But running your own node is what keeps the platform in the
        hands of the people on it — it strengthens the network, and it lets you
        mint: by helping produce blocks you build voting weight, so you help
        decide where Qortium goes next.
      </p>
      <div class="grid grid--2">
        <div class="card">
          <div class="tile__head tile__head--top">
            <span class="card__mark"><HomeMark size={30} title="Qortium Home" /></span>
            <h3>Let Home run it for you</h3>
          </div>
          <p class="muted">
            Home can set up and run the node software for you — the easiest path,
            and a great fit on a desktop that stays on. Install Home, then turn
            on your node.
          </p>
          <div class="btn-row">
            <a class="btn btn--ghost" href={RELEASES.home.releases}>Get Qortium Home</a>
          </div>
        </div>
        <div class="card">
          <div class="tile__head tile__head--top">
            <span class="card__mark"><CoreMark size={30} title="Qortium Core" /></span>
            <h3>Run the node software yourself</h3>
          </div>
          <ReleaseTag class="badge badge--preview" repo={RELEASES.core.repoSlug} />
          <p class="muted">
            Qortium Core is that same node software on its own — run it by hand on
            a server or an always-on machine without the app, or use it as a base
            to build your own chain. {RELEASES.core.platforms.join(', ')}. License <code>{RELEASES.core.license}</code>.
          </p>
          <div class="btn-row">
            <a class="btn btn--ghost" href={RELEASES.core.releases}>Get Qortium Core releases</a>
          </div>
        </div>
      </div>
      <div class="card">
        <h3>No port-forwarding needed</h3>
        <p class="muted">
          Running a reachable node used to mean opening a port on your router.
          Qortium can connect through I2P instead, so your node can take part
          even on home internet that blocks incoming connections — and you can
          route everything through I2P to keep your IP address private.
          <a href={withBase('/core')}>How connecting works</a>.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Previewnet</h2>
      <div class="card">
        <p class="muted">Previewnet is a temporary network for testing and planning the real chain. It will be reset, so don't rely on anything you create or trade there — only use what you're willing to lose.</p>
      </div>
    </div>
  </section>
</BaseLayout>
