---
import BaseLayout from '../layouts/BaseLayout.astro';
import CoreMark from '../components/CoreMark.astro';
import HomeMark from '../components/HomeMark.astro';
import ChatMark from '../components/ChatMark.astro';
import TrustMark from '../components/TrustMark.astro';
import ReleaseTag from '../components/ReleaseTag.astro';
import { withBase, RELEASES, CHAT, TRUST, absUrl } from '../data/site';

const title = 'Qortium downloads';
const description = 'Qortium Core and Home preview releases.';

const products = [
  {
    kind: 'core' as const,
    ...RELEASES.core,
    blurb: 'The network software — the chain itself.',
  },
  {
    kind: 'home' as const,
    ...RELEASES.home,
    blurb: 'Your wallet, the network, and content in one app — desktop and Android.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Qortium downloads',
  description,
  url: absUrl('/downloads'),
};
---
<BaseLayout title={title} description={description} path="/downloads" jsonLd={jsonLd}>
  <section class="hero">
    <div class="container">
      <h1>Preview releases</h1>
      <p class="lede measure">
        Install Qortium Home, join Previewnet, and help shape what comes next.
      </p>
      <p class="muted">Early preview builds, for testing only.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Core and Home</h2>
      <div class="grid grid--2">
        {products.map((p) => (
          <div class="card">
            <span class="card__mark">
              {p.kind === 'core' ? <CoreMark size={30} title={p.name} /> : <HomeMark size={30} title={p.name} />}
            </span>
            <h3>{p.name}</h3>
            <ReleaseTag class="badge badge--preview" repo={p.repoSlug} />
            <p class="muted">{p.blurb} License <code>{p.license}</code>.</p>
            <p class="muted">{p.platforms.join(', ')}.</p>
            <div class="btn-row">
              <a class="btn btn--primary" href={p.releases}>Get {p.name} releases</a>
            </div>
          </div>
        ))}
        <div class="card">
          <span class="card__mark">
            <ChatMark size={30} title={CHAT.name} />
          </span>
          <h3>{CHAT.name}</h3>
          <p class="muted">A QDN app — no separate download. Open <code>{CHAT.qdnResource}</code> in Home.</p>
        </div>
        <div class="card">
          <span class="card__mark">
            <TrustMark size={30} title={TRUST.name} />
          </span>
          <h3>{TRUST.name}</h3>
          <p class="muted">A QDN app — no separate download. Open <code>{TRUST.qdnResource}</code> in Home.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Previewnet</h2>
      <div class="card">
        <p class="muted">Previewnet is a temporary network for testing and planning the real chain. It will be reset, so don't rely on anything you create or trade there — only use what you're willing to lose.</p>
      </div>
    </div>
  </section>
</BaseLayout>
