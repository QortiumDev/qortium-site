---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeMark from '../components/HomeMark.astro';
import { withBase, RELEASES, LINKS, absUrl } from '../data/site';

const title = 'Qortium Home';
const description = 'One simple app that opens the whole platform: your account, the network, and everything published on it.';

const wallets = [
  'Encrypted wallet backups on desktop and Android.',
  'Hold several addresses in one wallet.',
  'Import a private key to make a password-protected wallet.',
  'Your password is only asked for when your key is actually needed to sign something — reading, browsing, and watching never prompt for it.',
  'Locked by default — your key stays encrypted until the moment it is used, and locks again when you step away.',
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Qortium Home',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Linux, macOS, Windows, Android',
  license: RELEASES.home.license,
  url: absUrl('/home'),
  description: 'One simple app that opens the whole platform: your account, the network, and everything published on it.',
  sameAs: [LINKS.homeRepo],
};
---
<BaseLayout title={title} description={description} path="/home" jsonLd={jsonLd}>
  <section class="hero">
    <div class="container">
      <div class="hero-head">
        <HomeMark size={44} title="Qortium Home" />
        <h1>One app, your doorway to the whole platform</h1>
      </div>
      <p class="lede measure">
        Home is the one app you open to use Qortium. Your account, the network,
        and everything people publish on it all live in one place — nothing
        extra to install or piece together.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary" href={withBase('/downloads')}>Download</a>
        <a class="btn btn--ghost" href={LINKS.homeRepo}>Open qortium-home</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>What it does</h2>
      <div class="grid grid--2">
        <div class="card">
          <h3>Your wallet, your keys</h3>
          <ul class="muted">
            {wallets.map((w) => <li>{w}</li>)}
          </ul>
        </div>
        <div class="card">
          <h3>Connect to the network</h3>
          <p class="muted">
            Open Home and it can put you on the network straight away, through a
            public network of nodes. When you're ready, Home can set up and run
            your own node for you — which strengthens the network and lets you
            mint to earn a say in it. <a href={withBase('/downloads')}>Run your own node</a>.
          </p>
          <p class="muted">
            If your router blocks incoming connections, Qortium can route through
            I2P so you can still find peers — and you can choose to hide your IP
            address entirely. <a href={withBase('/core')}>How connecting works</a>.
          </p>
        </div>
        <div class="card">
          <h3>Open what people publish</h3>
          <p class="muted">
            Read posts, watch and listen to media, visit pages and apps, and open
            shared files — all published on the network and reached just by name.
          </p>
        </div>
        <div class="card">
          <h3>Browse in tabs</h3>
          <p class="muted">
            Move between everything in tabs, and give each tab its own signed-in
            account — so you can use several accounts at once, with no need to run
            multiple copies of the app.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Good to know</h2>
      <div class="grid grid--2">
        <div class="card">
          <h3>You approve everything</h3>
          <p class="muted">
            Home never acts for an app without asking. You stay in control and
            approve every action yourself.
          </p>
        </div>
        <div class="card">
          <h3>Works with Qortal too</h3>
          <p class="muted">
            Qortium shares its roots with Qortal, so Home can also open Qortal's
            apps, content, and data — today through a public Qortal node, and
            soon directly across the Qortal network.
          </p>
        </div>
        <div class="card">
          <h3>Chat is a separate app</h3>
          <p class="muted">
            Messaging lives in its own app that runs inside Home.
            <a href={withBase('/chat')}>See Qortium Chat</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
