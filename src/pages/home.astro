---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeMark from '../components/HomeMark.astro';
import { withBase, RELEASES, LINKS, SITE } from '../data/site';

const title = 'Qortium Home';
const description = 'Your wallet, the network, and decentralized content in one app.';

const wallets = [
  'Encrypted wallet backups on desktop and Android.',
  'Hold several addresses in one wallet.',
  'Import a private key to make a password-protected wallet.',
  'Unlocked per session, locked when you step away.',
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Qortium Home',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Linux, macOS, Windows, Android',
  license: RELEASES.home.license,
  url: SITE.origin + withBase('/home'),
  description: 'Your wallet, the network, and decentralized content in one app.',
  sameAs: [LINKS.homeRepo],
};
---
<BaseLayout title={title} description={description} path="/home" jsonLd={jsonLd}>
  <section class="hero">
    <div class="container">
      <div class="hero-head">
        <HomeMark size={44} title="Qortium Home" />
        <h1>Your wallet and the network, in one app</h1>
      </div>
      <p class="lede measure">
        Home keeps your wallet, the network, and decentralized content together in
        one simple app.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary" href={withBase('/downloads')}>Download</a>
        <a class="btn btn--ghost" href={LINKS.homeRepo}>Open qortium-home</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>What it does</h2>
      <div class="grid grid--2">
        <div class="card">
          <h3>Your wallet, your keys</h3>
          <ul class="muted">
            {wallets.map((w) => <li>{w}</li>)}
          </ul>
        </div>
        <div class="card">
          <h3>Connect to the network</h3>
          <p class="muted">
            Home is becoming a lite client, so you can use the network without
            running your own node. It can still set up and run one for you if you
            prefer.
          </p>
        </div>
        <div class="card">
          <h3>Browse decentralized content</h3>
          <p class="muted">
            Open apps, websites, media, and files on the decentralized network,
            just by name.
          </p>
        </div>
        <div class="card">
          <h3>Browse in tabs</h3>
          <p class="muted">
            Each tab keeps its own history and active wallet.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Good to know</h2>
      <div class="grid grid--2">
        <div class="card">
          <h3>You approve everything</h3>
          <p class="muted">
            Home never acts for an app without asking; you approve every action
            yourself.
          </p>
        </div>
        <div class="card">
          <h3>Works with Qortal too</h3>
          <p class="muted">
            Home can also browse Qortal's apps, content, and data — today through a
            public Qortal node, and soon directly across the Qortal network.
          </p>
        </div>
        <div class="card">
          <h3>Chat is a separate app</h3>
          <p class="muted">
            Chat lives in its own app that runs inside Home.
            <a href={withBase('/chat')}>See Qortium Chat</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
