---
import BaseLayout from '../layouts/BaseLayout.astro';
import Logo from '../components/Logo.astro';
import CoreMark from '../components/CoreMark.astro';
import HomeMark from '../components/HomeMark.astro';
import ChatMark from '../components/ChatMark.astro';
import TrustMark from '../components/TrustMark.astro';
import { withBase, LINKS } from '../data/site';

const title = 'Qortium | A simpler foundation for blockchains';
const description =
  'Qortium is a streamlined foundation for blockchains, grown out of Qortal, with one app, Qortium Home, for your wallet, the network, and content.';

const reasons = [
  {
    h: 'A cleaner foundation',
    p: 'Qortium trims Qortal down to a simpler base that is easier to understand and to build a new chain on.',
  },
  {
    h: 'Everything in one app',
    p: 'Qortium Home gives you wallets, the network, and content in one place.',
  },
  {
    h: 'No coin forced on you',
    p: 'A new chain starts with no built-in coin; the community decides if one is ever added.',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Qortium',
    url: 'https://qortal.link/Qortium',
    description:
      'Qortium is a streamlined foundation for blockchains, grown out of Qortal, with one app for your wallet, the network, and content.',
    sameAs: [LINKS.coreRepo, LINKS.homeRepo],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Qortium',
    url: 'https://qortal.link/Qortium',
  },
];
---
<BaseLayout title={title} description={description} path="/" jsonLd={jsonLd}>
  <!-- 1. HERO -->
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <h1>A simpler foundation for blockchains</h1>
        <p class="lede measure">
          Qortium is a streamlined foundation for blockchains, grown out of
          Qortal, with one simple app, Qortium Home, for your wallet, the
          network, and decentralized content.
        </p>
        <div class="btn-row">
          <a class="btn btn--primary" href={withBase('/downloads')}>Join Previewnet</a>
          <a class="btn btn--ghost" href={withBase('/compare')}>Compare</a>
        </div>
      </div>
      <div class="hero__frame" aria-hidden="true">
        <Logo size={150} class="hero-mark" />
      </div>
    </div>
  </section>

  <!-- 2. WHY -->
  <section class="section">
    <div class="container">
      <h2>Why Qortium exists</h2>
      <div class="grid grid--2">
        {reasons.map((r) => (
          <div class="card">
            <h3>{r.h}</h3>
            <p class="muted">{r.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. LIVE NOW ON PREVIEWNET -->
  <section class="section">
    <div class="container">
      <h2>Live now on Previewnet</h2>
      <p class="lede measure">
        Qortium is already running on Previewnet — a live network for testing and
        shaping the protocol, though not yet a permanent mainnet. There's no coin
        by choice; whether to add one is an open decision for the community.
      </p>
      <p class="measure">
        This is the moment to get involved — join Previewnet, try it out, and help
        decide where Qortium goes next.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary" href={withBase('/downloads')}>Join Previewnet</a>
      </div>
    </div>
  </section>

  <!-- 4. PRODUCT SPLIT -->
  <section class="section">
    <div class="container">
      <h2>Core, Home, Chat, Trust</h2>
      <div class="grid grid--4">
        <a class="card card--link" href={withBase('/core')}>
          <span class="card__mark"><CoreMark size={40} title="Qortium Core" /></span>
          <h3>Qortium Core</h3>
          <p class="muted">The network software, the chain itself, open source.</p>
        </a>
        <a class="card card--link" href={withBase('/home')}>
          <span class="card__mark"><HomeMark size={40} title="Qortium Home" /></span>
          <h3>Qortium Home</h3>
          <p class="muted">A desktop and Android app for your wallet, the network, and content.</p>
        </a>
        <a class="card card--link" href={withBase('/chat')}>
          <span class="card__mark"><ChatMark size={40} title="Qortium Chat" /></span>
          <h3>Qortium Chat</h3>
          <p class="muted">Private and public group chat that runs inside Home.</p>
        </a>
        <a class="card card--link" href={withBase('/trust')}>
          <span class="card__mark"><TrustMark size={40} title="Qortium Trust" /></span>
          <h3>Qortium Trust</h3>
          <p class="muted">See and build account reputation, inside Home.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
