---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroMark from '../components/HeroMark.astro';
import CoreMark from '../components/CoreMark.astro';
import HomeMark from '../components/HomeMark.astro';
import ChatMark from '../components/ChatMark.astro';
import TrustMark from '../components/TrustMark.astro';
import AppMark from '../components/AppMark.astro';
import { withBase, LINKS, absUrl } from '../data/site';

const title = 'Qortium | A community-run internet platform';
const description =
  'Qortium is a complete internet platform, built by the community and not controlled by any company. Post, message, publish, and store files on one network you help steer.';

const reasons = [
  {
    h: 'A complete platform',
    p: 'The everyday things you go online to do — sharing posts and media, messaging people, publishing pages and apps, storing files — all on one network instead of a separate tool for each.',
  },
  {
    h: 'Built by the community',
    p: 'The direction is shaped by the people who use it, not a company or a closed group. Anyone can join, take part, and help decide where it goes next.',
  },
  {
    h: 'Not controlled by a company',
    p: 'No one sits above the network to censor, ban, or shut people out. Instead you decide what you see — you locally hide whatever you do not want.',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Qortium',
    url: absUrl('/'),
    description:
      'Qortium is a complete internet platform, built by the community and not controlled by any company.',
    sameAs: [LINKS.coreRepo, LINKS.homeRepo],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Qortium',
    url: absUrl('/'),
    description:
      'A complete internet platform for posting, messaging, publishing, and storing files — built by the community and not controlled by any company.',
  },
];
---
<BaseLayout title={title} description={description} path="/" jsonLd={jsonLd}>
  <!-- 1. HERO -->
  <section class="hero">
    <div class="container hero__grid">
      <div>
        <h1>An internet platform the community owns</h1>
        <p class="lede measure">
          Qortium is a complete internet platform, which is built by the
          community, and not controlled by any company.
        </p>
        <p class="measure">
          Share posts and media, message people, publish your own pages and
          apps, and store files — all on one network, with no company in the
          middle.
        </p>
        <div class="btn-row">
          <a class="btn btn--primary" href={withBase('/downloads')}>Join Previewnet</a>
          <a class="btn btn--ghost" href={withBase('/compare')}>Compare</a>
        </div>
      </div>
      <div class="hero__frame">
        <HeroMark size={168} />
      </div>
    </div>
  </section>

  <!-- 2. WHAT THAT MEANS -->
  <section class="section">
    <div class="container">
      <h2>What that means</h2>
      <div class="grid grid--2">
        {reasons.map((r) => (
          <div class="card">
            <h3>{r.h}</h3>
            <p class="muted">{r.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. LIVE NOW ON PREVIEWNET -->
  <section class="section">
    <div class="container">
      <h2>Live now on Previewnet</h2>
      <p class="lede measure">
        Qortium is already running on Previewnet — a live network for testing
        and shaping the protocol, not yet a permanent mainnet. It will be reset
        along the way, so this is a place to take part and help shape what comes
        next.
      </p>
      <p class="measure">
        There is no coin, by choice. A new network starts with none of its own,
        and whether one is ever added is an open decision for the community. You
        do not have to buy anything to join in.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary" href={withBase('/downloads')}>Join Previewnet</a>
      </div>
    </div>
  </section>

  <!-- 4. PRODUCT SPLIT -->
  <section class="section">
    <div class="container">
      <h2>Core, Home, and the app suite</h2>
      <div class="grid grid--4">
        <a class="card card--link" href={withBase('/core')}>
          <div class="tile__head">
            <span class="card__mark"><CoreMark size={40} title="Qortium Core" /></span>
            <h3>Qortium Core</h3>
          </div>
          <p class="muted">Run a piece of the network yourself and keep it open to everyone.</p>
        </a>
        <a class="card card--link" href={withBase('/home')}>
          <div class="tile__head">
            <span class="card__mark"><HomeMark size={40} title="Qortium Home" /></span>
            <h3>Qortium Home</h3>
          </div>
          <p class="muted">Browse, post, and manage your account from one app on desktop and Android.</p>
        </a>
        <a class="card card--link" href={withBase('/chat')}>
          <div class="tile__head">
            <span class="card__mark"><ChatMark size={40} title="Qortium Chat" /></span>
            <h3>Qortium Chat</h3>
          </div>
          <p class="muted">Message friends one to one or talk in group rooms, right inside Home.</p>
        </a>
        <a class="card card--link" href={withBase('/trust')}>
          <div class="tile__head">
            <span class="card__mark"><TrustMark size={40} title="Qortium Trust" /></span>
            <h3>Qortium Trust</h3>
          </div>
          <p class="muted">Check who you can rely on and build your own reputation over time.</p>
        </a>
        <a class="card card--link" href={withBase('/apps')}>
          <div class="tile__head">
            <span class="card__mark"><AppMark app="apps" size={40} title="Qortium apps" /></span>
            <h3>More apps</h3>
          </div>
          <p class="muted">Wallet, Names, Groups, Profiles, Chain Explorer, Help, and more — all open right inside Home.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
