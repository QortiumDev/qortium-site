---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustMark from '../components/TrustMark.astro';
import QdnLink from '../components/QdnLink.astro';
import { TRUST, LINKS, withBase } from '../data/site';

const title = 'Qortium Trust';
const description =
  'There is no central authority handing down who to trust here — the people on the network rate each other, and you decide what you see.';

const highlights = [
  {
    h: 'A picture everyone shares',
    p: 'People rate each other right on the network, and everyone sees the same scores. There is no hidden ranking and no company deciding for you.',
  },
  {
    h: 'No biometrics, no outside service',
    p: 'Reputation comes only from how people act on the network. There is no face scan, no ID check, and no third party in the loop.',
  },
  {
    h: 'Only abusive accounts get blocked',
    p: 'Reputation does not erase your history. It only raises or lowers how much your votes and ratings count, and accounts flagged as abusive are kept from minting.',
  },
  {
    h: 'Hard to fake',
    p: 'You cannot prop up your own reputation with a pile of fake accounts. Scores have to be earned from real participants.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Qortium Trust',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Runs in Qortium Home (desktop & Android)',
  license: TRUST.license,
  url: TRUST.repo,
  description:
    'There is no central authority handing down who to trust here — the people on the network rate each other, and you decide what you see.',
  sameAs: [TRUST.repo],
};
---
<BaseLayout title={title} description={description} path="/trust" jsonLd={jsonLd}>
  <section class="hero">
    <div class="container">
      <div class="hero-head">
        <TrustMark size={44} title="Qortium Trust" />
        <h1>The community decides who to trust</h1>
      </div>
      <p class="lede measure">
        Trustworthiness isn't ranked from the top down here. Instead the
        people on the network rate each other, that reputation lives on the chain
        for everyone to see, and in the end you choose what you take part in and
        what you ignore.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary" href={withBase('/downloads')}>Get Qortium Home</a>
        <a class="btn btn--ghost" href={LINKS.trustRepo}>Source repo</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>How trust works here</h2>
      <div class="grid grid--2">
        {highlights.map((c) => (
          <div class="card">
            <h3>{c.h}</h3>
            <p class="muted">{c.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Where the reputation comes from</h2>
      <div class="grid grid--2">
        <div class="card">
          <h3>Accounts rate each other</h3>
          <p class="muted">
            Reputation is built from ratings people sign on the chain, not handed down
            from anyone in charge.
          </p>
        </div>
        <div class="card">
          <h3>Trust starts with active participants</h3>
          <p class="muted">
            It is rooted in the people currently helping run the network, not a fixed
            authority that can be captured.
          </p>
        </div>
        <div class="card">
          <h3>More trust, more say</h3>
          <p class="muted">
            Accounts the network trusts more carry more weight when decisions are put
            to a vote.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Get started</h2>
      <div class="card">
        <p class="muted">
          Open Trust inside Qortium Home (<QdnLink resource={TRUST.qdnResource} />).
        </p>
        <div class="btn-row">
          <a class="btn btn--ghost" href={LINKS.trustRepo}>Source repo</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
